\import Code
\import LambdaBox
\import Data.Bool
\import Data.Maybe

-- =============================================================================
-- S-expression serializer for the lambda-box AST, translated by hand from
-- lean-to-lambdabox's Serialize.lean (Lean `class Serialize`+`instance`s
-- over `sexpr`).
--
-- Translation notes:
--
-- * Arend has no open-ended typeclass dispatch the way this was used in Lean
--   (one `instance` per concrete type, resolved by elaboration). Instead,
--   every type gets its own named `toSExpr<Type>` function, matching how
--   ToJava.ard is structured (no generic dispatch, functions named per case).
--   Anywhere Lean used a *polymorphic* instance (`[Serialize α] => Serialize
--   (List α)`, `Option α`, pairs), the Arend version takes the per-element
--   serializer as an explicit function argument instead of instance search
--   (`toSExprArray`, `toSExprMaybe`).
--
-- * `sexpr.atom` holds a `Code`, not a `String`: String is opaque in Arend
--   (see Code.ard), and numeral atoms (`natToStr`/`intToStr`) are themselves
--   multi-fragment Code values, not single String literals -- `atom` has to
--   be able to hold those without concatenating them into one String first.
--   `sexpr.toString` becomes `sexprToCode : Sexpr -> Code`; flattening to an
--   actual printed String happens only at the very end, via `printArr`.
--
-- * Per ToJava.ard's established termination-checker idiom: recursing over
--   an `Array LBTerm`/`Array (FixDef LBTerm)`/case-branch bodies through a
--   *separate* generic helper (like `toSExprArray`) breaks the structural
--   link the checker needs, because the helper's own recursive call to `f`
--   isn't syntactically a call to `toSExprLBTerm` on a subterm of the
--   original argument. So `toSExprLBTerm` inlines all of its own Array
--   recursion directly (`\lam i => toSExprLBTerm (args i)`, etc.), and only
--   uses `toSExprArray` for arrays of *other* (non-self-referential) types
--   (`Array ConstructorBody`, `Array BinderName`, ...).
--
-- * Lean's `ModPath` (in Serialize.lean's `LeanToLambdaBox.Basic`) has no
--   `MPbound` constructor (functors aren't modeled there); Arend's `ModPath`
--   keeps `mpBound` (per the earlier-established Coq/Arend vs. Lean
--   divergence). `toSExprModPath`'s `mpBound` case is therefore an
--   extension with no Lean counterpart to mirror.
-- =============================================================================


-- ---------------------------------------------------------------------------
-- Sexpr and its rendering to Code.
-- ---------------------------------------------------------------------------

\data Sexpr
  | atomS Code
  | listS (Array Sexpr)

\func joinWithSpaces (xs : Array Code) : Code \elim xs
  | nil => nilC
  | x :: nil => x
  | x :: xs => x <+> litC " " <+> joinWithSpaces xs

\func sexprToCode (e : Sexpr) : Code \elim e
  | atomS c => c
  | listS xs =>
    litC "(" <+> joinWithSpaces (\new Array Code xs.len (\lam i => sexprToCode (xs i))) <+> litC ")"

\func quoteAtom (c : Code) : Code => litC "\"" <+> c <+> litC "\""

-- Peregrine's build has `cstr_as_blocks = false` (EWellformed.all_env_flags),
-- meaning `tConstruct` must always carry an EMPTY arg list -- constructor
-- application is expressed via ordinary curried `tApp` on the bare
-- constructor instead (confirmed empirically: a non-empty tConstruct arg
-- list fails wellformedness with "Constructor args non-empty",
-- CheckWf.v:131). `args` here are already-rendered Sexprs (not LBTerm), so
-- this is a plain, non-Sexpr-recursive fold -- no termination concern.
\func wrapTApp (base : Sexpr) (args : Array Sexpr) : Sexpr \elim args
  | nil => base
  | a :: rest => wrapTApp (listS (atomS (litC "tApp") :: base :: a :: nil)) rest


-- ---------------------------------------------------------------------------
-- Generic helpers, replacing Lean's polymorphic `Serialize` instances.
-- Safe to use freely (see note above): neither is itself Sexpr-recursive, so
-- there's nothing for the termination checker to prove about them.
-- ---------------------------------------------------------------------------

\func toSExprArray {A : \Type} (f : A -> Sexpr) (xs : Array A) : Sexpr =>
  listS (\new Array Sexpr xs.len (\lam i => f (xs i)))

\func toSExprMaybe {A : \Type} (f : A -> Sexpr) (m : Maybe A) : Sexpr \elim m
  | nothing => atomS (litC "None")
  | just a => listS (atomS (litC "Some") :: f a :: nil)


-- ---------------------------------------------------------------------------
-- Base types.
-- ---------------------------------------------------------------------------

\func toSExprNat (n : Nat) : Sexpr => atomS (natToStr n)

\func toSExprIdent (s : Ident) : Sexpr => atomS (quoteAtom (litC s))

\func toSExprBool (b : Bool) : Sexpr \elim b
  | false => atomS (litC "false")
  | true => atomS (litC "true")

\func toSExprBinderName (b : BinderName) : Sexpr \elim b
  | named fv => listS (atomS (litC "nNamed") :: toSExprIdent fv.varName :: nil)
  | anon => atomS (litC "nAnon")

\func toSExprModPath (mp : ModPath) : Sexpr \elim mp
  | mpFile dp => listS (atomS (litC "MPfile") :: toSExprArray toSExprIdent dp :: nil)
  | mpBound dp id n =>                                                              -- extension, no Lean counterpart
    listS (atomS (litC "MPbound") :: toSExprArray toSExprIdent dp :: toSExprIdent id :: toSExprNat n :: nil)
  | mpDot mp' id => listS (atomS (litC "MPdot") :: toSExprModPath mp' :: toSExprIdent id :: nil)

\func toSExprKername (k : Kername) : Sexpr =>
  listS (toSExprModPath k.kerModPath :: toSExprIdent k.kerName :: nil)

\func toSExprInductiveId (ind : InductiveId) : Sexpr =>
  listS (atomS (litC "inductive") :: toSExprKername ind.indMutualBlock :: toSExprNat ind.indIdx :: nil)

\func toSExprProjectionInfo (p : ProjectionInfo) : Sexpr =>
  listS (atomS (litC "projection") :: toSExprInductiveId p.projIndType
                                        :: toSExprNat p.projParamCount :: toSExprNat p.projFieldIdx :: nil)

\func toSExprPrimTag (t : PrimTag) : Sexpr \elim t
  | primInt => atomS (litC "primInt")

-- Lean's Serialize.lean quotes the BitVec 63 payload as a decimal string, but
-- that's specific to Lean's own serializer; Peregrine's native Ceres-based
-- serializer (Integral_sint/Serialize_Integral in CeresSerialize.v) emits the
-- primInt payload as a bare Num atom, NOT a quoted string -- a quoted "1"
-- fails Peregrine's deserializer ("could not read integral type, got a
-- non-Num atom"). So: bare `intToStr`, no `quoteAtom`.
\func toSExprPrimVal (pv : PrimVal) : Sexpr \elim pv
  | (primInt, i) => listS (toSExprPrimTag primInt :: atomS (intToStr i) :: nil)


-- ---------------------------------------------------------------------------
-- LBTerm (the mutual LBTerm.to_sexpr / edef.to_sexpr in Lean, flattened here
-- since FixDef's body is inlined the same way ToJava.ard inlines it in `fix`).
-- ---------------------------------------------------------------------------

\func toSExprLBTerm (t : LBTerm) : Sexpr \elim t
  | box => atomS (litC "tBox")
  | bvar n => listS (atomS (litC "tRel") :: toSExprNat n :: nil)
  | fvar _ => atomS (litC "tVar_UNREACHABLE")     -- Lean: `unreachable!` -- should never occur post de-Bruijn conversion
  | lambda na body => listS (atomS (litC "tLambda") :: toSExprBinderName na :: toSExprLBTerm body :: nil)
  | letIn na val body =>
    listS (atomS (litC "tLetIn") :: toSExprBinderName na :: toSExprLBTerm val :: toSExprLBTerm body :: nil)
  | app u v => listS (atomS (litC "tApp") :: toSExprLBTerm u :: toSExprLBTerm v :: nil)
  | const k => listS (atomS (litC "tConst") :: toSExprKername k :: nil)
  | construct ind n args =>
    wrapTApp (listS (atomS (litC "tConstruct") :: toSExprInductiveId ind :: toSExprNat n :: listS nil :: nil))
        (\new Array Sexpr args.len (\lam i => toSExprLBTerm (args i)))
  | case ind npars scrut brs =>
    listS (atomS (litC "tCase")
      :: listS (toSExprInductiveId ind :: toSExprNat npars :: nil)
           :: toSExprLBTerm scrut
                :: listS (\new Array Sexpr brs.len (\lam i =>
        listS (toSExprArray toSExprBinderName (brs i).1 :: toSExprLBTerm (brs i).2 :: nil)))
                     :: nil)
  | proj p c => listS (atomS (litC "tProj") :: toSExprProjectionInfo p :: toSExprLBTerm c :: nil)
  | fix defs idx =>
    listS (atomS (litC "tFix")
      :: listS (\new Array Sexpr defs.len (\lam j =>
        listS (atomS (litC "def") :: toSExprBinderName (defs j).defName
                                       :: toSExprLBTerm (defs j).defBody :: toSExprNat (defs j).principalArgIdx :: nil)))
           :: toSExprNat idx :: nil)
  | prim pv => listS (atomS (litC "tPrim") :: toSExprPrimVal pv :: nil)


-- ---------------------------------------------------------------------------
-- Declaration-level types. None of these are self-referential via Arrays the
-- way LBTerm is, so toSExprArray/toSExprMaybe are safe to use throughout.
-- ---------------------------------------------------------------------------

\func toSExprConstructorBody (c : ConstructorBody) : Sexpr =>
  listS (atomS (litC "constructor_body") :: toSExprIdent c.cstrName :: toSExprNat c.cstrNargs :: nil)

\func toSExprProjectionBody (p : ProjectionBody) : Sexpr =>
  listS (atomS (litC "projection_body") :: toSExprIdent p.projBodyName :: nil)

\func toSExprAllowedEliminations (a : AllowedEliminations) : Sexpr \elim a
  | IntoSProp => atomS (litC "IntoSProp")
  | IntoPropSProp => atomS (litC "IntoPropSProp")
  | IntoSetPropSProp => atomS (litC "IntoSetPropSProp")
  | IntoAny => atomS (litC "IntoAny")

\func toSExprOneInductiveBody (o : OneInductiveBody) : Sexpr =>
  listS (atomS (litC "one_inductive_body") :: toSExprIdent o.indName :: toSExprBool o.indPropositional
                                                                          :: toSExprAllowedEliminations o.indKelim :: toSExprArray toSExprConstructorBody o.indCtors
                                                                                                                        :: toSExprArray toSExprProjectionBody o.indProjs :: nil)

\func toSExprRecursivityKind (r : RecursivityKind) : Sexpr \elim r
  | finite => atomS (litC "Finite")
  | cofinite => atomS (litC "CoFinite")
  | bifinite => atomS (litC "BiFinite")

\func toSExprMutualInductiveBody (m : MutualInductiveBody) : Sexpr =>
  listS (atomS (litC "mutual_inductive_body") :: toSExprRecursivityKind m.indFinite :: toSExprNat m.indNpars
                                                                                         :: toSExprArray toSExprOneInductiveBody m.indBodies :: nil)

\func toSExprConstantBody (c : ConstantBody) : Sexpr =>
  listS (atomS (litC "constant_body") :: toSExprMaybe toSExprLBTerm c.cstBody :: nil)

\func toSExprGlobalDecl (g : GlobalDecl) : Sexpr \elim g
  | constantDecl cb => listS (atomS (litC "ConstantDecl") :: toSExprConstantBody cb :: nil)
  | inductiveDecl mib => listS (atomS (litC "InductiveDecl") :: toSExprMutualInductiveBody mib :: nil)

\func toSExprGlobalDeclEntry (p : \Sigma Kername GlobalDecl) : Sexpr =>
  listS (toSExprKername p.1 :: toSExprGlobalDecl p.2 :: nil)

\func toSExprGlobalDeclarations (ds : GlobalDeclarations) : Sexpr =>
  toSExprArray toSExprGlobalDeclEntry ds

\func toSExprASTType (a : ASTType) : Sexpr \elim a
  | untyped ds term => listS (atomS (litC "Untyped") :: toSExprGlobalDeclarations ds :: toSExprMaybe toSExprLBTerm term :: nil)


-- ---------------------------------------------------------------------------
-- Extraction-attribute-remapping types (tail of Basic.lean / Serialize.lean).
-- ---------------------------------------------------------------------------

\func toSExprRemappedInductive (r : RemappedInductive) : Sexpr =>
  listS (atomS (litC "remapped_inductive") :: toSExprIdent r.reIndName
                                                :: toSExprArray toSExprIdent r.reIndCtors :: toSExprMaybe toSExprIdent r.reIndMatch :: nil)

\func toSExprExtractInductive (e : ExtractInductive) : Sexpr =>
  listS (atomS (litC "extract_inductive") :: toSExprArray toSExprKername e.extractCstrs :: toSExprKername e.extractElim :: nil)

\func toSExprRemapInductive (r : RemapInductive) : Sexpr \elim r
  | knIndRemap re => listS (atomS (litC "KnIndRemap") :: toSExprExtractInductive re :: nil)
  | stringIndRemap re => listS (atomS (litC "StringIndRemap") :: toSExprRemappedInductive re :: nil)

\func toSExprInductiveMapping (m : InductiveMapping) : Sexpr =>
  listS (atomS (litC "inductive_mapping") :: toSExprKername m.indMapKn
                                               :: toSExprIdent m.indMapS :: toSExprArray toSExprNat m.indMapN :: nil)

\func toSExprRemappedConstant (r : RemappedConstant) : Sexpr =>
  listS (atomS (litC "remapped_constant") :: toSExprMaybe toSExprIdent r.reConstExt
                                               :: toSExprNat r.reConstArity :: toSExprBool r.reConstGC :: toSExprBool r.reConstInl
                                                                                                            :: toSExprIdent r.reConstS :: nil)

\func toSExprAttributesConfig (a : AttributesConfig) : Sexpr =>
  listS (atomS (litC "attributes_config")
    :: toSExprArray toSExprKername a.acInlinings
         :: toSExprArray (\lam p => listS (toSExprKername p.1 :: toSExprRemappedConstant p.2 :: nil)) a.acConstRemappings
              :: toSExprArray (\lam p => listS (toSExprInductiveId p.1 :: toSExprRemapInductive p.2 :: nil)) a.acIndRemappings
                   :: toSExprArray toSExprInductiveMapping a.acCstrReorders
                        :: toSExprArray (\lam p => listS (toSExprKername p.1 :: toSExprIdent p.2 :: nil)) a.acCustomAttributes
                             :: nil)


-- ---------------------------------------------------------------------------
-- Entry point.
-- ---------------------------------------------------------------------------

\import Debug.Meta

-- LBProgram always has an entry term; ASTType's is optional (a bare library
-- has none) -- bridge by wrapping LBProgram's term in `just`.
\func LambdaBoxToSrting (p : LBProgram) =>
  sexprToCode (toSExprASTType (untyped p.1 (just p.2)))
