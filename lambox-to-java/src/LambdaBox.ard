-- Encoding of the lambda-box (λ□) language in Arend.
--
-- Sources / inspiration:
--   * MetaRocq EAst.v   : erasure/theories/EAst.v   (the canonical λ□ `term`)
--   * lean-to-lambdabox : LeanToLambdaBox/Basic.lean (the `LBTerm` adaptation)
--   * Links
--     - https://github.com/peregrine-project/lean-to-lambdabox/blob/main/LeanToLambdaBox/Basic.lean
--     - https://metarocq.github.io/html/MetaRocq.Erasure.EAst.html
--     - https://metacoq.github.io/v1.2-8.16/MetaCoq.Erasure.EAst.html
--     - https://github.com/MetaRocq/metarocq/blob/coq-8.20/erasure/theories/EAst.v
-- We follow the LBTerm shape (cleaner names, locally-nameless friendly):
--   * keep `fvar` (a locally-nameless free variable, à la Lean) alongside `bvar`
--     (de Bruijn).  The canonical EAst λ□ uses only `bvar`; drop `fvar` if you
--     build de Bruijn directly during erasure.
--   * drop `tVar`, `tEvar`, `tCoFix`, `tLazy`, `tForce` (LBTerm does the same):
--     they are not needed for a strict, non-coinductive `\Set`+IO fragment.
--   * `prim` is simplified: MetaRocq/LBTerm carry primitive ints (BitVec 63);
--     Arend has no fixed-width BitVec, so we model the payload with Prelude `Int`.

\import Data.Bool
\import Data.Maybe
-- All sequences are `Array` (Prelude) so ToJava can recurse inline via `xs i` and
-- there is no `List`/`Array` `nil`/`::` ambiguity. (No `\import Data.List`.)

-- When to use String, type synonym (ident) or class (FreeVarId) ?

\func Ident => String
\func DirPath => Array String

\class FreeVarId
  | varName : String

\data BinderName
  | named FreeVarId
  | anon  -- Identifiers that are allowed to be anonymous (i.e. "_" in concrete syntax).

\data ModPath
  | mpFile DirPath
  | mpBound DirPath Ident Nat
  | mpDot ModPath Ident

\record Kername (kerModPath : ModPath) (kerName : Ident)

\record InductiveId (indMutualBlock : Kername) (indIdx : Nat)
-- Q (Lean) : Which of the mutually inductive types defined in this block is used here?

\record ProjectionInfo
  (projIndType : InductiveId)
  (projParamCount : Nat)  -- number of (non-let) parameters
  (projFieldIdx : Nat)  -- argument to project

\record FixDef (term : \Type)
  | defName : BinderName
  | defBody : term
  | principalArgIdx : Nat  -- Principal/structural argument for recursion

\data PrimTag
  | primInt
-- | primFloat
-- | primList

\func PrimModel (_ : PrimTag) : \Set  -- TODO : is this ok to be a \Set ?
  | primInt => Int
-- MetaRocq uses a different prim model
-- https://metarocq.github.io/html/MetaRocq.Erasure.EPrimitive.html#prim_val

\func PrimVal : \Type => \Sigma (t : PrimTag) (PrimModel t)


-- ---------------------------------------------------------------------------
-- The Lambda Box Term
--  https://metarocq.github.io/html/MetaRocq.Erasure.EAst.html#term
--  https://github.com/peregrine-project/lean-to-lambdabox/blob/main/LeanToLambdaBox/Basic.lean#L90
-- ---------------------------------------------------------------------------

\data LBTerm
  | box  -- represents computation irrelevant things, like proofs and types
  | bvar Nat  -- bound variable, accessed as a de Bruijn index
  | fvar FreeVarId  -- free variables (e.g. in a goal)
  -- tEvar  (not part of Lean pipeline?)
  | lambda BinderName LBTerm  -- \lam x => x + 1
  | letIn BinderName LBTerm LBTerm  -- \let | x => 1 \in x + 1
  | app LBTerm LBTerm  -- f x
  | const Kername  --  a constant living in the environment
  | construct InductiveId Nat {- index of the constructor used -} (Array LBTerm)  -- \data ...  (Array so ToJava can recurse inline via `args i`)
  | case InductiveId Nat {- number of parameters -} LBTerm (Array (\Sigma (Array BinderName) LBTerm))
  -- \case {Type, number of parameters} expr \with ...
  | proj ProjectionInfo LBTerm
  | fix (Array (FixDef LBTerm)) Nat {- index of the one mutually defined function we want to access -}
  -- | tCoFix  (not part of Lean pipeline?)
  | prim PrimVal
-- | lazy  -- lazy evaltiation? (not part of Lean pipeline?)
-- | force  -- eager evaltiation? (not part of Lean pipeline?)


-- ---------------------------------------------------------------------------
-- The Lambda Box Program
--  https://metarocq.github.io/html/MetaRocq.Erasure.EAst.html#program
--  https://github.com/peregrine-project/lean-to-lambdabox/blob/main/LeanToLambdaBox/Basic.lean#L182
-- ---------------------------------------------------------------------------

\record ConstructorBody (cstrName : Ident) (cstrNargs : Nat)

\record ProjectionBody (projBodyName : Ident)

\data AllowedEliminations  -- TODO : adjust for Arend?
  | IntoSProp
  | IntoPropSProp
  | IntoSetPropSProp
  | IntoAny

\record OneInductiveBody
  (indName : Ident)
  (indPropositional : Bool)   -- Should always be false? since erasure should remove anything which ends up in Prop
  (indKelim : AllowedEliminations)
  (indCtors : Array ConstructorBody)
  (indProjs : Array ProjectionBody)  -- This is only about giving user-visible names to projections, but `peregrine` complains about wellformedness if it is empty.

\data RecursivityKind
  | finite
  | cofinite  -- Lean doesn't have primitive coinductive types, but including this here anyway to match the MetaCoq side.
  | bifinite

\record MutualInductiveBody
  (indFinite : RecursivityKind)  -- Should always be finite ?
  (indNpars : Nat)  -- Number of parameters to this family of mutually inductive types.
  (indBodies : Array OneInductiveBody)

\record ConstantBody (cstBody : Maybe LBTerm)

\data GlobalDecl
  | constantDecl ConstantBody
  | inductiveDecl MutualInductiveBody

-- The first declarations to be added to the context are the deepest/first-consed in the list.
\func GlobalDeclarations : \Type => Array (\Sigma Kername GlobalDecl)

\func LBProgram : \Type => \Sigma GlobalDeclarations LBTerm
